//Verificar si un numero es positivo es positivos o negativo
Algoritmo NumPosNeg
	//Entrada
	Escribir "===Números Positivos o Negativos==="
	Definir num Como Entero
	Escribir "Dame un número entero"
	Leer num
	//Proceso 
	//Salida
	Si num>=0 Entonces
		Escribir"Es un número positivo"
	SiNo
		Escribir"Es un número negativo"
	Fin Si
	
FinAlgoritmo
